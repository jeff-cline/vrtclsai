// Predictive Intelligence Exchange — data model
// Lead-gen + quote/order flow + manual credit issuance + file/endpoint delivery.
// Third-party data and delivery infrastructure live outside this system.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  CUSTOMER
}

enum CreditTxnKind {
  GRANT
  REVOKE
  CONSUME
  REFUND
  ADJUSTMENT
}

enum OrderStatus {
  DRAFT          // saved in-progress quote, no credits deducted yet
  PENDING        // customer placed the order, credits deducted, awaiting fulfillment
  IN_PROGRESS    // admin actively fulfilling
  DELIVERED      // complete
  CANCELED       // canceled / refunded
}

enum DeliveryMethod {
  FILE_DOWNLOAD  // admin uploads file(s) to the order, customer downloads from portal
  PING_POST      // POST records to customer-provided HTTPS endpoint
  SFTP           // SFTP push to customer-provided server
  API_PULL       // customer pulls from our API
  CUSTOM         // 3rd-party-mediated delivery (cost not included disclaimer applies)
}

model Organization {
  id            String              @id @default(cuid())
  name          String
  tier          String              @default("optimized")
  creditBalance Int                 @default(0)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  users         User[]
  creditTxns    CreditTxn[]
  orders        Order[]
  delivery      DeliveryPreference?
}

model User {
  id                 String        @id @default(cuid())
  email              String        @unique
  name               String?
  passwordHash       String
  mustChangePassword Boolean       @default(false)
  role               Role          @default(CUSTOMER)
  organizationId     String?
  organization       Organization? @relation(fields: [organizationId], references: [id])
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  lastLoginAt        DateTime?
  orders         Order[]       @relation("OrderRequestedBy")
  grantedCredits CreditTxn[]   @relation("GrantedBy")
  uploadedFiles  OrderFile[]   @relation("OrderFileUploadedBy")
  sessions       Session[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CreditTxn {
  id             String        @id @default(cuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  amount         Int
  kind           CreditTxnKind
  note           String?
  orderId        String?
  grantedById    String?
  grantedBy      User?         @relation("GrantedBy", fields: [grantedById], references: [id])
  createdAt      DateTime      @default(now())

  @@index([organizationId, createdAt])
}

model Order {
  id               String         @id @default(cuid())
  organizationId   String
  organization     Organization   @relation(fields: [organizationId], references: [id])
  requestedById    String
  requestedBy      User           @relation("OrderRequestedBy", fields: [requestedById], references: [id])
  industry         String
  region           String?
  volume           Int            // requested number of records
  filters          Json
  creditCost       Int            @default(0)
  status           OrderStatus    @default(DRAFT)
  deliveryMethod   DeliveryMethod @default(FILE_DOWNLOAD)
  deliveryEndpoint String?
  deliveryNotes    String?
  adminNotes       String?
  files            OrderFile[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  acceptedAt       DateTime?
  deliveredAt      DateTime?

  @@index([organizationId, status])
  @@index([status, createdAt])
}

model OrderFile {
  id           String   @id @default(cuid())
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  filename     String
  storagePath  String
  mimeType     String
  sizeBytes    Int
  uploadedById String?
  uploadedBy   User?    @relation("OrderFileUploadedBy", fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now())

  @@index([orderId, createdAt])
}

model DeliveryPreference {
  id              String         @id @default(cuid())
  organizationId  String         @unique
  organization    Organization   @relation(fields: [organizationId], references: [id])
  method          DeliveryMethod @default(FILE_DOWNLOAD)
  endpoint        String?
  notes           String?
  updatedAt       DateTime       @updatedAt
}

model DemoRequest {
  id        String   @id @default(cuid())
  name      String
  email     String
  company   String?
  phone     String?
  industry  String?
  volume    String?
  message   String?
  source    String? // "quote" | "demo" | other
  createdAt DateTime @default(now())

  @@index([createdAt])
}
